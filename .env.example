# copie este arquivo para .env e preencha os valores reais (.env não é versionado)

# string aleatória usada para assinar o cookie de sessão — qualquer texto longo e aleatório serve
SESSION_SECRET=troque-por-uma-string-aleatoria-longa

# usuário do backoffice
ADMIN_USER=sofia

# hash bcrypt da senha do backoffice — gere com: npm run gerar-hash -- "sua-senha-aqui"
ADMIN_PASSWORD_HASH=
